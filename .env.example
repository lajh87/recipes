APP_NAME=Heley Family Cookbook
APP_PORT=8080
APP_ENV=development

MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_SECURE=false
MINIO_BUCKET_NAME=recipe-library-ebooks

REDIS_URL=redis://redis:6379/5
REDIS_KEY_PREFIX=recipes

QDRANT_URL=http://qdrant:6333
QDRANT_COOKBOOK_COLLECTION=recipes-cookbooks
QDRANT_RECIPE_COLLECTION=recipes-recipe-chunks
QDRANT_VECTOR_SIZE=1536

OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_RECIPE_MODEL=gpt-5.4-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_SEARCH_MODEL=gpt-5.4-mini

UPLOAD_PREFIX=ebooks
DERIVED_PREFIX=derived
MAX_UPLOAD_MB=500
ALLOWED_EXTENSIONS=pdf,epub,mobi,azw3

DATASTORE_NETWORK_NAME=shared-datastores
