<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.lukeheley.recipes-backup</string>

  <key>WorkingDirectory</key>
  <string>/Users/lukeheley/Developer/recipes</string>

  <key>ProgramArguments</key>
  <array>
    <string>/Users/lukeheley/Developer/recipes/scripts/backup_recipes.sh</string>
    <string>/Users/lukeheley/Developer/recipes/scripts/recipes_backup.env</string>
  </array>

  <key>EnvironmentVariables</key>
  <dict>
    <key>PATH</key>
    <string>/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin</string>
  </dict>

  <key>StartCalendarInterval</key>
  <dict>
    <key>Weekday</key>
    <integer>1</integer>
    <key>Hour</key>
    <integer>2</integer>
    <key>Minute</key>
    <integer>0</integer>
  </dict>

  <key>StandardOutPath</key>
  <string>/Users/lukeheley/Library/Logs/recipes-backup.out.log</string>

  <key>StandardErrorPath</key>
  <string>/Users/lukeheley/Library/Logs/recipes-backup.err.log</string>

  <key>RunAtLoad</key>
  <false/>
</dict>
</plist>
