# OneDrive backup target. The script creates dated folders under this root.
BACKUP_ROOT="$HOME/Library/CloudStorage/OneDrive-Personal/Backups/recipes/weekly"
STAGING_ROOT="/tmp/recipes-backup-staging"
RETENTION_WEEKS=4
ALLOW_REPLACE_EXISTING_BACKUP=0

# GHCR image publishing. Run `docker login ghcr.io` before the first backup.
GHCR_REPOSITORY="ghcr.io/lajh87/recipes"
BUILD_IMAGE=1
PUSH_IMAGE=1

# Stop only the recipe app containers during export and import.
RECIPES_COMPOSE_FILE="/Users/lukeheley/Developer/recipes/docker-compose.yml"
STOP_APP_CONTAINERS=1
RESTORE_STAGING_ROOT="/tmp/recipes-restore-staging"

# MinIO app bucket
MINIO_ALIAS="recipes-local"
MINIO_URL="http://127.0.0.1:9000"
MINIO_BUCKET="recipe-library-ebooks"
MINIO_ROOT_USER="minioadmin"
MINIO_ROOT_PASSWORD="minioadmin"

# Redis app namespace
REDIS_URL="redis://127.0.0.1:6379/5"
REDIS_PREFIX="recipes:"
REDIS_CONTAINER_NAME="shared-redis"
PURGE_REDIS_PREFIX_ON_RESTORE=1

# Qdrant app collections
QDRANT_URL="http://127.0.0.1:6333"
QDRANT_COLLECTIONS="recipes-cookbooks recipes-recipe-chunks"
# QDRANT_API_KEY=""

# Optional encrypted backup of the app's .env file.
EXPORT_APP_ENV=0
APP_ENV_FILE_PATH="/Users/lukeheley/Developer/recipes/.env"
# GPG_RECIPIENT="your@email.example"
